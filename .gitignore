backend/.env
frontend/.env
frontend/.env.local

# ── Build output ──────────────────────────────────────────
frontend/dist/

# ── Logs ──────────────────────────────────────────────────
*.log

# ── OS / Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
