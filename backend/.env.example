# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# The public base URL — used to build short URLs in responses
BASE_URL=http://localhost:3000

# Allow requests from the React frontend (Vite runs on 5173)
CORS_ORIGIN=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://dev:devpass@localhost:5432/urlshortener

# Connection pool: min 2 open always, max 10 at peak
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# How long to keep a URL in Redis cache (seconds) — 1 hour
CACHE_TTL_SECONDS=3600

# ── Auth (JWT + bcrypt) ───────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=change-this-to-a-long-random-secret-key

# JWT expiry — token is valid for 7 days
JWT_EXPIRES_IN=7d

# bcrypt cost factor — higher = slower = more secure (12 is a good default)
BCRYPT_ROUNDS=12

# ── Rate Limiting ─────────────────────────────────────────
# 60-second sliding window
RATE_LIMIT_WINDOW_SECONDS=60

# Anonymous users: 10 shorten requests per minute
RATE_LIMIT_ANON_MAX=10

# Free users: 50 shorten requests per minute
RATE_LIMIT_FREE_MAX=50

# ── Analytics Worker ──────────────────────────────────────
# How often the worker flushes click events to Postgres (ms)
ANALYTICS_FLUSH_INTERVAL_MS=60000
