NODE_ENV=production
PORT=3000

# ── Database ───────────────────────────────────────────────
# Neon: get from neon.tech → your project → Connection Details → Node.js
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Redis (Upstash) ────────────────────────────────────────
# Upstash: get from upstash.com → your DB → Connect → Redis Client → copy rediss:// URL
REDIS_URL=rediss://default:your-token@your-host.upstash.io:6379

# ── Auth ───────────────────────────────────────────────────
# Generate a secure random string (32+ chars). Never share this.
JWT_SECRET=generate-a-long-random-secret-here
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── URLs ───────────────────────────────────────────────────
# Your deployed backend URL (set after deploy)
BASE_URL=https://your-api.onrender.com
# Your deployed frontend URL (for CORS — set after frontend deploy)
CORS_ORIGIN=https://your-app.vercel.app

# ── Cache ──────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_ANON_MAX=10
RATE_LIMIT_FREE_MAX=50

# ── Analytics Worker ───────────────────────────────────────
ANALYTICS_FLUSH_INTERVAL_MS=60000

# ── Connection Pool (free tier: keep small) ────────────────
DB_POOL_MIN=1
DB_POOL_MAX=5
